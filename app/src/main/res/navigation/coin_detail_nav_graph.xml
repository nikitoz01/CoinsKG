<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/coin_nav_graph"
    app:startDestination="@id/coinFragment">

    <fragment
        android:id="@+id/coinFragment"
        android:name="kg.mobile.coins.ui.fragment.coin.CoinFragment"
        android:label="CoinFragment" >
        <action
            android:id="@+id/action_coinFragment_to_coinDetailFragment"
            app:destination="@id/coinDetailFragment">
        <argument
            android:name="coinId"
            app:argType="integer" />
        </action>
        <argument
            android:name="categoryId"
            app:argType="string"
            app:nullable="true"
            android:defaultValue="@null" />
    </fragment>

    <dialog
        android:id="@+id/coinDetailFragment"
        android:name="kg.mobile.coins.ui.fragment.coindetail.CoinDetailFragment"
        android:label="CoinDetailFragment" >
        <argument
            android:name="coinId"
            app:argType="integer" />
    </dialog>


    <action android:id="@+id/action_global_coinFragment"
        app:destination="@id/coinFragment">
    <argument
        android:name="categoryId"
        app:argType="string" />
    </action>
</navigation>