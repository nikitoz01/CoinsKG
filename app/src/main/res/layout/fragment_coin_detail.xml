<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    tools:context=".CoinDetailFragment">

    <ImageView
        android:layout_width="200dp"
        android:layout_height="100dp"
        android:id="@+id/coinDetailImageView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginTop="10dp">
    </ImageView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:id="@+id/nameTextView"
        app:layout_constraintTop_toBottomOf="@+id/coinDetailImageView"
        app:layout_constraintStart_toStartOf="@+id/coinDetailImageView"
        app:layout_constraintEnd_toEndOf="@id/coinDetailImageView">
    </TextView>

</androidx.constraintlayout.widget.ConstraintLayout>